# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- Alpaca (paper-first) ---
# Create paper keys at https://app.alpaca.markets/ (Paper Trading -> API Keys)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# true = paper account (default, recommended). Set false ONLY after edge is proven.
ALPACA_PAPER=true

# --- LLM (existing research app + future Claude overlay) ---
# OpenAI still used by the legacy research agent in tools/fetch_stock_info.py
OPENAI_API_KEY=
# Anthropic used by the Phase 5 LLM overlay. Leave blank to disable overlay (pass-through).
ANTHROPIC_API_KEY=
# Optional: override the Claude model used for overlay (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Risk gate (Phase 3) ---
# Comma-separated tradeable symbols. Unset => the built-in 8-ticker mega-cap basket.
# The risk gate rejects any symbol outside this list.
RISK_ALLOWLIST=
# SQLite store for orders/trades/proposals. Shares the app's users.db by default.
PORTFOLIO_DB_PATH=users.db
# Presence of this file halts the order path (kill switch). Delete it to resume.
KILL_SWITCH_PATH=kill_switch.flag

# --- Autonomy (Phase 4) ---
# manual = proposals queued for dashboard approval; auto = execute directly (paper only).
AUTONOMY=manual

# --- Observability (Phase 6) ---
# Logging verbosity: DEBUG | INFO | WARNING. INFO is recommended for production.
LOG_LEVEL=INFO
# Slack-compatible incoming webhook URL. Leave blank to disable alerts.
# Create one at: Your Slack workspace → Apps → Incoming Webhooks → Add New Webhook
SLACK_WEBHOOK_URL=
# Reserved for Phase 7 SMTP email alerts (not yet wired).
ALERT_EMAIL=

# ── PHASE 7 GO-LIVE ─────────────────────────────────────────────────────────────
# ONLY flip ALPACA_PAPER=false after ALL of:
#   1. python scripts/go_live_gate.py --in-sample-end <date>  exits 0 (gate PASS)
#   2. python scripts/paper_trading_report.py              exits 0 (≥1 auto run, ≥1 fill)
#   3. Kill switch manually tested: engage → confirm halt → disengage → confirm resume
#   4. PDT rule confirmed: account equity ≥ $25k OR strategy trades < 3 round-trips/day
#
# Live Alpaca keys are SEPARATE from paper keys — create at app.alpaca.markets (Live).
# ALPACA_PAPER=false
# ALPACA_API_KEY=<live key>
# ALPACA_SECRET_KEY=<live secret>
