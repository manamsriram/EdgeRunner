# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- Alpaca (paper-first) ---
# Create paper keys at https://app.alpaca.markets/ (Paper Trading -> API Keys)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# true = paper account (default, recommended). Set false ONLY after edge is proven.
ALPACA_PAPER=true

# --- LLM overlay (Phase 5) ---
# OpenAI still used by the legacy research agent in tools/fetch_stock_info.py
OPENAI_API_KEY=
# Gemini: primary LLM (free tier, generous limits). Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: override the Gemini model (default: gemini-2.0-flash-lite)
GEMINI_MODEL=gemini-2.0-flash-lite
# Groq: secondary LLM (free tier, lower limits). Get a key at https://console.groq.com/
GROQ_API_KEY=
# Optional: override the Groq model (default: llama-3.1-8b-instant)
GROQ_MODEL=llama-3.1-8b-instant
# Anthropic: last-resort LLM (paid). Leave blank unless both Gemini and Groq are unavailable.
ANTHROPIC_API_KEY=
# Optional: override the Claude model (default: claude-haiku-4-5-20251001)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Risk gate (Phase 3) ---
# Comma-separated tradeable symbols. Unset => the built-in 8-ticker mega-cap basket.
# The risk gate rejects any symbol outside this list.
RISK_ALLOWLIST=
# SQLite store for orders/trades/proposals. Shares the app's users.db by default.
PORTFOLIO_DB_PATH=users.db
# Presence of this file halts the order path (kill switch). Delete it to resume.
KILL_SWITCH_PATH=kill_switch.flag

# --- Autonomy (Phase 4) ---
# manual = proposals queued for dashboard approval; auto = execute directly (paper only).
AUTONOMY=manual
# Presence of this file overrides AUTONOMY at runtime (dashboard toggle writes it).
# Contents: "manual" or "auto". Delete the file to fall back to AUTONOMY above.
AUTONOMY_OVERRIDE_PATH=autonomy_override.flag

# --- Risk circuit breaker ---
# Halt NEW buys once the day's account drawdown hits DAILY_LOSS_LIMIT_PCT. Exits
# are never blocked. Off by default; recommended true in production.
DAILY_LOSS_HALT_ENABLED=false
DAILY_LOSS_LIMIT_PCT=0.03

# --- Options (wheel / CSP-on-dip) ---
# Master switch + per-strategy flags. Options run only under AUTONOMY=auto.
# Collateral capped at MAX_OPTIONS_ALLOCATION_PCT of NAV (default 0.15).
OPTIONS_TRADING_ENABLED=false
WHEEL_STRATEGY_ENABLED=false
CSP_ON_DIP_ENABLED=false
MAX_OPTIONS_ALLOCATION_PCT=0.15

# --- Observability (Phase 6) ---
# Logging verbosity: DEBUG | INFO | WARNING. INFO is recommended for production.
LOG_LEVEL=INFO
# Slack-compatible incoming webhook URL. Leave blank to disable alerts.
# Create one at: Your Slack workspace → Apps → Incoming Webhooks → Add New Webhook
SLACK_WEBHOOK_URL=
# Reserved for Phase 7 SMTP email alerts (not yet wired).
ALERT_EMAIL=

# --- Phase 8: FastAPI + React frontend ---
# Secret used to sign JWT tokens. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-please
# Set true in production (HTTPS). Leave false for local dev.
SECURE_COOKIES=false
# React dev server origin for CORS (only matters during `npm run dev`).
FRONTEND_ORIGIN=http://localhost:5173

# ── PHASE 7 GO-LIVE ─────────────────────────────────────────────────────────────
# ONLY flip ALPACA_PAPER=false after ALL of:
#   1. python scripts/go_live_gate.py --in-sample-end <date>  exits 0 (gate PASS)
#   2. python scripts/paper_trading_report.py              exits 0 (≥1 auto run, ≥1 fill)
#   3. Kill switch manually tested: engage → confirm halt → disengage → confirm resume
#   4. PDT rule confirmed: account equity ≥ $25k OR strategy trades < 3 round-trips/day
#
# Live Alpaca keys are SEPARATE from paper keys — create at app.alpaca.markets (Live).
# ALPACA_PAPER=false
# ALPACA_API_KEY=<live key>
# ALPACA_SECRET_KEY=<live secret>
